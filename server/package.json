{
  "name": "skill-sage-server",
  "version": "1.0.0",
  "description": "Backend server for Skill Sage AI Resume Screening Portal",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "npx prisma db push && node src/index.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0"
  }
}
